# =============================================================================
# LLM Provider Configuration
# =============================================================================

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API Key (for accessing multiple LLM providers)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default LLM Provider (google or openrouter)
# Can be changed via Settings UI or API
DEFAULT_LLM_PROVIDER=google

# Default Model Name
# Google options: gemini-2.0-flash-exp, gemini-2.0-flash-thinking-exp-1219, gemini-2.5-flash, gemini-2.5-pro
# OpenRouter options: openai/gpt-4o-mini, openai/gpt-4o, anthropic/claude-3.5-sonnet, etc.
DEFAULT_LLM_MODEL=gemini-2.5-flash
# =============================================================================
# Server Configuration
# =============================================================================

API_HOST=localhost
API_PORT=8000

# =============================================================================
# Optional: Generation Settings
# =============================================================================

MAX_TOKENS=8192
TEMPERATURE=0.7

# Debug mode (set to true to enable SQL query logging)
DEBUG=false

# =============================================================================
# Translation Service Configuration (DeepL API)
# =============================================================================

# DeepL API Key (get free key from https://www.deepl.com/pro-api)
# Free tier: 500,000 characters/month
# API key ends with :fx for free tier
DEEPL_API_KEY=your_deepl_api_key_here:fx

# DeepL API Tier (free or pro)
DEEPL_API_TIER=free

# Enable/disable translation service (true or false)
DEEPL_ENABLED=false

# Supported languages: hu (Hungarian), de (German), es (Spanish), it (Italian)
# Also supported: fr (French), pt (Portuguese), pl (Polish), nl (Dutch)

# =============================================================================
# Image Generation (Pollinations.ai)
# =============================================================================

# Optional: Pollinations API key for higher rate limits
# Get one at https://pollinations.ai
POLLINATIONS_API_KEY=your_pollinations_api_key_here

# =============================================================================
# Vector Store / RAG Configuration
# =============================================================================

# Enable RAG (set to false for legacy full-text loading)
VECTOR_STORE_ENABLED=true

# ChromaDB persistence path (relative to backend/)
VECTOR_STORE_PATH=data/vector_store

# Embedding model (Gemini embeddings via API)
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768
EMBEDDING_TASK_TYPE=RETRIEVAL_DOCUMENT  # For indexing documents
EMBEDDING_QUERY_TASK_TYPE=RETRIEVAL_QUERY  # For search queries

# Retrieval parameters
RAG_GROUND_TRUTH_TOP_K=10     # Number of chunks to retrieve from ground truth
RAG_PREVIOUS_GEN_TOP_K=8      # Number of chunks from previous generations
RAG_CHUNK_SIZE=800            # Target tokens per chunk (for new chunking)
RAG_CHUNK_OVERLAP=50          # Token overlap between chunks

# Query strategy
RAG_QUERY_COUNT=4             # Number of queries to generate (multi-query)

# Debug modes
RAG_DEBUG_MODE=false          # Set to true to log retrieval details
DEBUG_AGENT_PROMPTS=false     # Set to true to save agent prompts to files (backend/data/agent_prompts/)
CONTEXT_RETRIEVAL_MODE=legacy    # Context retrieval mode: 'rag' or 'legacy' (can be changed in UI without restart)
